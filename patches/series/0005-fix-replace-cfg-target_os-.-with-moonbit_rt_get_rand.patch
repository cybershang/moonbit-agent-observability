index 00000000..ddb0abfc
--- /dev/null
+++ b/patches/add-moonbit_rt_get_random-to-runtime.patch
@@ -0,0 +1,38 @@
+From: Yingjie Shang <cybershang>
+Date: Tue, 16 Jun 2026
+Subject: [PATCH] runtime: add moonbit_rt_get_random for cross-platform entropy
+
+This patch adds `moonbit_rt_get_random()` to the MoonBit C runtime.
+It provides a single FFI entry point that selects the OS-specific
+secure random API at the C preprocessor level:
+
+- Windows: uses `rand_s()`
+- POSIX (Linux/macOS): uses `getentropy()`
+
+This eliminates the need for `#cfg(target_os=...)` in MoonBit code,
+which is not supported by the MoonBit compiler.
+
+--- a/lib/runtime.c
++++ b/lib/runtime.c
+@@ -2559,6 +2559,21 @@ MOONBIT_EXPORT void moonbit_rt_unset_env_var(moonbit_bytes_t key) {
+ #endif
+ }
+
++MOONBIT_EXPORT int32_t moonbit_rt_get_random(moonbit_bytes_t buf, int32_t len) {
++  if (len <= 0) return 0;
++#ifdef _WIN32
++  for (int32_t i = 0; i < len; i += 4) {
++    unsigned int word;
++    if (rand_s(&word) != 0) return -1;
++    int32_t copy = (len - i < 4) ? (len - i) : 4;
++    memcpy(buf + i, &word, copy);
++  }
++  return 0;
++#else
++  return getentropy(buf, (size_t)len);
++#endif
++}
++
+ MOONBIT_EXPORT FILE *moonbit_fopen_ffi(moonbit_bytes_t path,
+                                        moonbit_bytes_t mode) {
+   return fopen((const char *)path, (const char *)mode);
