From e10b8310da4fd0a41779af8f7c73cbe85a8faa6b Mon Sep 17 00:00:00 2001
From: Yingjie Shang <dev@yingjie.dev>
Date: Tue, 16 Jun 2026 21:05:01 +0800
Subject: [PATCH 2/5] fix(env): use getentropy for portable native entropy

getrandom(2) is not available on macOS, causing stable-check to fail
with undefined symbol '_getrandom'. Switch to getentropy(), which is
available on macOS, Linux (glibc 2.25+), and BSDs.

getentropy is limited to 256 bytes per call, so chunk larger requests.
---
 env/env_native.mbt | 22 +++++++++++++++-------
 1 file changed, 15 insertions(+), 7 deletions(-)

diff --git a/env/env_native.mbt b/env/env_native.mbt
index 3c0e3f46..3fd5943d 100644
--- a/env/env_native.mbt
+++ b/env/env_native.mbt
@@ -182,15 +182,23 @@ fn rand_internal(n : Int) -> Bytes? {
   if n <= 0 {
     return Some(b"")
   }
-  let buf = Bytes::new(n)
-  let got = getrandom(buf, n.reinterpret_as_uint(), 0U)
-  if got < n {
-    None
-  } else {
-    Some(buf)
+  let buf : FixedArray[Byte] = FixedArray::make(n, b'\x00')
+  let chunk : FixedArray[Byte] = FixedArray::make(256, b'\x00')
+  let mut offset = 0
+  while offset < n {
+    let len = if n - offset < 256 { n - offset } else { 256 }
+    let rc = getentropy(chunk, len.reinterpret_as_uint())
+    if rc != 0 {
+      return None
+    }
+    for i = 0; i < len; i = i + 1 {
+      buf[offset + i] = chunk[i]
+    }
+    offset += len
   }
+  Some(Bytes::from_array(buf))
 }
 
 ///|
 #borrow(buf)
-extern "c" fn getrandom(buf : Bytes, len : UInt, flags : UInt) -> Int = "getrandom"
+extern "c" fn getentropy(buf : FixedArray[Byte], len : UInt) -> Int = "getentropy"
