 }
+
+///|
+/// Get `n` random bytes from a platform entropy source.
+/// Returns `Some(bytes)` when the platform can provide secure random bytes,
+/// and `None` on targets/environments that do not support entropy.
+pub fn rand(n : Int) -> Bytes? {
+  rand_internal(n)
+}
diff --git a/env/env_js.mbt b/env/env_js.mbt
index e080c313..6d1ef0ed 100644
--- a/env/env_js.mbt
+++ b/env/env_js.mbt
@@ -119,3 +119,22 @@ extern "js" fn unset_env_var_ffi(key : String) -> Unit =
   #|     delete process.env[key];
   #|   }
   #| }
+
+///|
+fn rand_internal(n : Int) -> Bytes? {
+  if n <= 0 {
+    return Some(b"")
+  }
+  get_random_values_js(n)
+}
+
+///|
+extern "js" fn get_random_values_js(n : Int) -> Bytes? =
+  #| function(n) {
+  #|   if (typeof crypto === "undefined" || typeof crypto.getRandomValues !== "function") {
+  #|     return null;
+  #|   }
+  #|   const arr = new Uint8Array(n);
+  #|   crypto.getRandomValues(arr);
+  #|   return arr;
+  #| }
diff --git a/env/env_native.mbt b/env/env_native.mbt
index c433f4fe..3c0e3f46 100644
--- a/env/env_native.mbt
+++ b/env/env_native.mbt
@@ -176,3 +176,21 @@ fn unset_env_var_internal(key : String) -> Unit {
 ///|
 #borrow(_key)
 extern "c" fn unset_env_var_ffi(_key : Bytes) -> Unit = "moonbit_rt_unset_env_var"
+
+///|
+fn rand_internal(n : Int) -> Bytes? {
+  if n <= 0 {
+    return Some(b"")
+  }
+  let buf = Bytes::new(n)
+  let got = getrandom(buf, n.reinterpret_as_uint(), 0U)
+  if got < n {
+    None
+  } else {
+    Some(buf)
+  }
+}
+
+///|
+#borrow(buf)
+extern "c" fn getrandom(buf : Bytes, len : UInt, flags : UInt) -> Int = "getrandom"
