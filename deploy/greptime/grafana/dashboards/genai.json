        {
          "refId": "Trace ID",
          "editorType": "code",
          "rawSql": "SELECT trace_id, span_id, parent_span_id, service_name, span_name, CAST(timestamp AS INT64) / 1000000 as ts_ms, CAST(duration_nano AS FLOAT64) / 1000000 as dur_ms, json_to_string(span_events) as span_events, \"span_attributes.gen_ai.provider.name\", \"span_attributes.gen_ai.operation.name\", \"span_attributes.gen_ai.request.model\", \"span_attributes.gen_ai.request.max_tokens\", \"span_attributes.server.address\", span_status_code, \"span_attributes.gen_ai.input.messages\", \"span_attributes.gen_ai.output.messages\", \"span_attributes.gen_ai.tool.name\", \"span_attributes.gen_ai.tool.call.arguments\", \"span_attributes.gen_ai.tool.call.result\", \"span_attributes.app.agent.tool_count\", \"span_attributes.app.prompt.length\", \"span_attributes.app.response.length\", \"span_attributes.app.agent.reached_max_turns\", \"span_attributes.app.llm.capture_content\", \"span_attributes.app.llm.tool_calls.count\", \"span_attributes.app.tool.result.length\", \"resource_attributes.telemetry.sdk.name\", \"resource_attributes.telemetry.sdk.language\", \"resource_attributes.telemetry.sdk.version\" FROM opentelemetry_traces WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND trace_id = COALESCE(NULLIF(${trace_id:sqlstring}, ''), (SELECT trace_id FROM opentelemetry_traces WHERE timestamp >= $__fromTime AND timestamp <= $__toTime ORDER BY timestamp DESC LIMIT 1)) ORDER BY timestamp",
          "builderOptions": {
            "database": "public",
            "table": "opentelemetry_traces",
            "queryType": "traces",
            "columns": [
              {
                "name": "trace_id",
                "hint": "trace_id"
              },
              {
                "name": "span_id",
                "hint": "trace_span_id"
              },
              {
                "name": "parent_span_id",
                "hint": "trace_parent_span_id"
              },
              {
                "name": "service_name",
                "hint": "trace_service_name"
              },
              {
                "name": "span_name",
                "hint": "trace_operation_name"
              },
              {
                "name": "timestamp",
                "hint": "time"
              },
              {
                "name": "duration_nano",
                "hint": "trace_duration_time"
              },
              {
                "name": "span_events"
              },
              {
                "name": "span_attributes.gen_ai.provider.name",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.operation.name",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.request.model",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.request.max_tokens",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.server.address",
                "hint": "trace_tags"
              },
              {
                "name": "span_status_code",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.input.messages",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.output.messages",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.tool.name",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.tool.call.arguments",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.gen_ai.tool.call.result",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.agent.tool_count",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.prompt.length",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.response.length",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.agent.reached_max_turns",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.llm.capture_content",
                "hint": "trace_tags"
              },
              {
                "name": "span_attributes.app.llm.tool_calls.count",
