    {
      "type": "table",
      "title": "Recent Conversations",
      "description": "LLM prompt and completion logs captured via OTel GenAI instrumentation.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 60
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_GREPTIMEDB}"
      },
      "targets": [
        {
          "editorMode": "code",
          "rawSql": "SELECT timestamp AS time, trace_id, CASE WHEN json_get_string(parse_json(body), 'message.role') IS NOT NULL THEN json_get_string(parse_json(body), 'message.role') ELSE 'user' END AS role, COALESCE(json_get_string(parse_json(body), 'message.content'), json_get_string(parse_json(body), 'content')) AS content FROM genai_conversations WHERE $__timeFilter(timestamp) AND ('${search}' = '' OR matches_term(body, '${search}')) ORDER BY timestamp DESC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "/d/agent-observability-greptime/agent-observability-greptime?var-trace_id=${__data.fields.trace_id}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "content"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 600
              },
              {
                "id": "custom.inspect",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "role"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "user": {
                        "color": "blue",
                        "text": "user"
                      },
                      "assistant": {
                        "color": "green",
                        "text": "assistant"
                      },
                      "system": {
                        "color": "orange",
                        "text": "system"
                      },
                      "tool": {
                        "color": "purple",
                        "text": "tool"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
