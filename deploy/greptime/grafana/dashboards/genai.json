      "targets": [
        {
          "editorMode": "code",
          "rawSql": "SELECT timestamp AS time, trace_id, `span_attributes.gen_ai.request.model` AS model, span_name, span_status_code AS status, ROUND(duration_nano / 1000000, 0) AS duration_ms, `span_attributes.gen_ai.usage.input_tokens` AS input_tokens, `span_attributes.gen_ai.usage.output_tokens` AS output_tokens, `span_attributes.gen_ai.response.finish_reasons` AS finish_reason FROM opentelemetry_traces WHERE $__timeFilter(timestamp) AND `span_attributes.gen_ai.provider.name` IS NOT NULL ORDER BY timestamp DESC LIMIT 50",
