# OpenTelemetry
OTEL_STDOUT=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
CAPTURE_CONTENT=true

# GreptimeDB-specific routing (only used when endpoint points to GreptimeDB).
# GREPTIME_TRACE_PIPELINE=greptime_trace_v1
# GREPTIME_LOG_TABLE=genai_conversations

# Optional: override the default service name shown in Jaeger / backends.
# If unset, the application uses "agent-observability".
# OTEL_SERVICE_NAME=agent-observability

# Optional: tune the batch span processor.
# OTEL_BSP_MAX_QUEUE_SIZE=64
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=16
# OTEL_BSP_SCHEDULE_DELAY=1000
# OTEL_BSP_EXPORT_TIMEOUT=5000

# LLM provider configuration
LLM_API_KEY=sk-your-api-key-here
LLM_PROVIDER=stepfun
LLM_BASE_URL=https://api.stepfun.com/v1
LLM_MODEL=step-3.7-flash
LLM_MAX_TOKENS=1024

# Agent behavior
AGENT_MAX_TOOL_TURNS=10

# QWeather configuration (used by the get_weather / lookup_city tools)
# Get a free key at https://dev.qweather.com/docs/start/
# For the new QWeather Platform API, use QWEATHER_TOKEN (JWT) and QWEATHER_API_HOST.
# Legacy Web API keys are also accepted as a fallback.
QWEATHER_TOKEN=your-qweather-token-here
QWEATHER_API_HOST=https://devapi.qweather.com
